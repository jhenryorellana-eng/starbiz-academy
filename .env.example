DIRECT_URL="postgresql://postgres.pduqjkdoxocdrbhounen:[TU-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Auth
JWT_SECRET="[GENERA-UN-SECRETO-LARGO-Y-ALEATORIO]"
